{
    "hooks": {
        "UserPromptSubmit": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "export PATH=\"$PATH:/Users/andjelaacic/Library/Python/3.11/bin\" && agora-code inject --quiet 2>/dev/null || true"
                    },
                    {
                        "type": "command",
                        "command": "export PATH=\"$PATH:/Users/andjelaacic/Library/Python/3.11/bin\" && .claude/hooks/on-prompt.sh"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Read",
                "hooks": [
                    {
                        "type": "command",
                        "command": "export PATH=\"$PATH:/Users/andjelaacic/Library/Python/3.11/bin\" && .claude/hooks/pre-read.sh"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "export PATH=\"$PATH:/Users/andjelaacic/Library/Python/3.11/bin\" && agora-code scan . --cache --quiet 2>/dev/null || true"
                    },
                    {
                        "type": "command",
                        "command": "export PATH=\"$PATH:/Users/andjelaacic/Library/Python/3.11/bin\" && python3 -c \"import sys,json,subprocess; d=json.loads(sys.stdin.read()); fp=(d.get('tool_input') or {}).get('file_path',''); subprocess.run(['/Users/andjelaacic/Library/Python/3.11/bin/agora-code','track-diff',fp]) if fp else None\" 2>/dev/null || true"
                    }
                ]
            }
        ],
        "PreCompact": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "export PATH=\"$PATH:/Users/andjelaacic/Library/Python/3.11/bin\" && agora-code checkpoint --quiet 2>/dev/null || true"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "export PATH=\"$PATH:/Users/andjelaacic/Library/Python/3.11/bin\" && agora-code checkpoint --quiet 2>/dev/null || true"
                    }
                ]
            }
        ]
    }
}
