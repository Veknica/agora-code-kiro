{
    "version": 1,
    "hooks": {
        "sessionStart": [
            {
                "command": ".cursor/hooks/session-start.sh"
            }
        ],
        "preToolUse": [
            {
                "command": ".cursor/hooks/pre-read.sh",
                "matcher": "Read"
            }
        ],
        "postToolUse": [
            {
                "command": ".cursor/hooks/post-tool.sh"
            }
        ],
        "afterFileEdit": [
            {
                "command": ".cursor/hooks/after-file-edit.sh"
            }
        ],
        "preCompact": [
            {
                "command": ".cursor/hooks/pre-compact.sh"
            }
        ],
        "sessionEnd": [
            {
                "command": ".cursor/hooks/session-end.sh"
            }
        ]
    }
}
